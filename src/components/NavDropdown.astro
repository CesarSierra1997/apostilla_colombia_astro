---
interface SubmenuItem {
  label: string;
  url: string;
}

interface NavOption {
  label: string;
  url?: string;
  class?: string;
  hasSubmenu?: boolean;
  submenu?: SubmenuItem[];
}

interface Props {
  id: string;         // ej: "apostilla" | "otros"
  label: string;      // texto que aparece en el botón
  options: NavOption[];
}

const { id, label, options } = Astro.props;
---

<div class="relative nav-dropdown-wrapper" data-dropdown={id}>
  <!-- Trigger -->
  <button
    id={`${id}-toggle`}
    aria-haspopup="true"
    aria-expanded="false"
    class="flex items-center gap-1 px-2 py-2 rounded-md hover:scale-105 transition-all duration-300 cursor-pointer w-full text-left"
  >
    <span>{label}</span>
    <svg
      id={`${id}-chevron`}
      xmlns="http://www.w3.org/2000/svg"
      class="w-4 h-4 transition-transform duration-300 ml-auto flex-shrink-0"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>

  <!-- Desktop dropdown -->
  <div
    id={`${id}-menu`}
    class="
      absolute left-0 z-30 hidden w-60 mt-2 rounded-xl
      border border-white/20 shadow-xl
      bg-white/80 dark:bg-gray-800/90 backdrop-blur-md
      text-sm p-1.5 origin-top
      scale-95 opacity-0 transition-all duration-200
    "
    role="menu"
  >
    <ul>
      {options.map((item, index) => (
        <li role="none" class="relative">
          {item.hasSubmenu ? (
            <>
              <button
                data-submenu-trigger={`${id}-${index}`}
                class="w-full flex items-center justify-between px-3 py-2 rounded-lg hover:bg-red-600/15 transition-colors text-left"
              >
                <span>{item.label}</span>
                <svg
                  data-submenu-icon={`${id}-${index}`}
                  class="w-4 h-4 transition-transform duration-200 flex-shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </button>
              <div
                data-submenu={`${id}-${index}`}
                class="hidden ml-2 mt-1 space-y-0.5 pl-2 border-l-2 border-red-300/50"
              >
                {item.submenu?.map((sub) => (
                  <a
                    role="menuitem"
                    href={sub.url}
                    class="block px-3 py-1.5 rounded-lg hover:bg-red-600/15 transition-colors"
                  >
                    {sub.label}
                  </a>
                ))}
              </div>
            </>
          ) : (
            <a
              role="menuitem"
              href={item.url}
              class={`block px-3 py-2 rounded-lg hover:bg-red-600/15 transition-colors ${item.class ?? ""}`}
            >
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>
  </div>
</div>

<script define:vars={{ id }}>
  function initDropdown(id) {
    const toggle = document.getElementById(`${id}-toggle`);
    const menu = document.getElementById(`${id}-menu`);
    const chevron = document.getElementById(`${id}-chevron`);
    if (!toggle || !menu) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      menu.classList.remove("hidden");
      requestAnimationFrame(() => {
        menu.classList.remove("scale-95", "opacity-0");
        menu.classList.add("scale-100", "opacity-100");
      });
      toggle.setAttribute("aria-expanded", "true");
      chevron?.classList.add("rotate-180");
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.remove("scale-100", "opacity-100");
      menu.classList.add("scale-95", "opacity-0");
      toggle.setAttribute("aria-expanded", "false");
      chevron?.classList.remove("rotate-180");
      setTimeout(() => {
        if (!isOpen) menu.classList.add("hidden");
      }, 200);
    }

    toggle.addEventListener("click", (e) => {
      e.stopPropagation();
      isOpen ? closeMenu() : openMenu();
    });

    // Submenus
    document.querySelectorAll(`[data-submenu-trigger^="${id}-"]`).forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const key = btn.dataset.submenuTrigger;
        const sub = document.querySelector(`[data-submenu="${key}"]`);
        const icon = document.querySelector(`[data-submenu-icon="${key}"]`);
        if (!sub) return;
        const open = !sub.classList.contains("hidden");
        sub.classList.toggle("hidden", open);
        icon?.classList.toggle("rotate-90", !open);
      });
    });

    document.addEventListener("click", (e) => {
      if (!menu.contains(e.target) && !toggle.contains(e.target)) closeMenu();
    });
  }

  document.addEventListener("DOMContentLoaded", () => initDropdown(id));
  document.addEventListener("astro:page-load", () => initDropdown(id));
</script>
